generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ChatLogStatus {
  success
  upstream_error
  aborted
  stream_error
}

model ChatLog {
  id            String        @id @default(uuid())
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  message       String
  sessionId     String?

  requestId     String?
  ip            String?
  userAgent     String?

  rawSse        String        @default("")
  finalText     String        @default("")

  status        ChatLogStatus
  upstreamStatus Int?
  errorDetail   String?
  durationMs    Int?

  @@index([createdAt])
  @@index([sessionId])
  @@index([status])
}

/// RAG chunks + ingest runs — must match `scripts/ingest/ingest.py` and AI retrieval SQL.
model IngestRun {
  id        String   @id @default(uuid()) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  isActive  Boolean  @default(false) @map("is_active")

  chunks Chunk[]

  @@map("ingest_runs")
}

model Chunk {
  id          String   @id
  source      String
  content     String
  metadata    Json     @default("{}")
  ingestRunId String?  @map("ingest_run_id") @db.Uuid
  ingestedAt  DateTime @default(now()) @map("ingested_at")
  embedding   Unsupported("vector(768)")?

  ingestRun IngestRun? @relation(fields: [ingestRunId], references: [id], onDelete: SetNull)

  @@map("chunks")
  @@index([embedding])
  @@index([ingestRunId])
}
