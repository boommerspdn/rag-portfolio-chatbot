# Local: docker-compose service db. Neon: postgresql+asyncpg://...@ep-....neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql+asyncpg://<POSTGRES_USER>:<POSTGRES_PASSWORD>@localhost:5432/<POSTGRES_DB>
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
EMBEDDING_MODEL=text-embedding-005
CHAT_MODEL=gemini-2.5-flash
TOP_K_CHUNKS=5
# Local only — omit on Cloud Run (uses attached service account instead)
# GOOGLE_APPLICATION_CREDENTIALS=/app/config/gcloud/application_default_credentials.json
#
# Cloud Run: set the same variables via --env-vars-file or GitHub Actions; omit GOOGLE_APPLICATION_CREDENTIALS.
# Enable pgvector on Neon (CREATE EXTENSION IF NOT EXISTS vector;).
