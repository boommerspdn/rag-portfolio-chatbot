# PostgreSQL — used by docker-compose for the db service and the ai service DATABASE_URL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=get_to_know_me

# Path to gcloud CLI config — run: gcloud auth application-default login
GCLOUD_CONFIG_DIR=C:/Users/you/AppData/Roaming/gcloud

# NestJS (apps/api) → FastAPI (apps/ai) base URL when running in docker-compose
AI_BASE_URL=http://ai:8000

# NestJS (apps/api) database connection (host/local tools, prisma migrate)
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/get_to_know_me
